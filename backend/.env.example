# Environment Variables Template
# Copy this to .env and add your actual API keys

# Choose ONE LLM Provider (at least):
OPENAI_API_KEY=sk-...
# OR
ANTHROPIC_API_KEY=sk-ant-...
# OR
XAI_API_KEY=xai-...

# Twilio (optional - runs in mock mode without)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Stripe (optional - runs in mock mode without)
STRIPE_SECRET_KEY=sk_test_...

# Database (optional - uses in-memory storage without)
DATABASE_URL=postgresql://user:password@localhost:5432/disaster_direct

# Environment
ENV=development
