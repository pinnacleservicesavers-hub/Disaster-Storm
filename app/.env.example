# Environment
ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/disaster_direct

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# DocuSign (E-signatures)
DOCUSIGN_API_KEY=your_docusign_api_key

# LienItNow (Legal compliance)
LIENITNOW_API_KEY=your_lienitnow_api_key

# Weather Services
GETAMBEE_API_KEY=your_ambee_api_key
XWEATHER_CLIENT_ID=your_xweather_client_id
XWEATHER_CLIENT_SECRET=your_xweather_client_secret

# Property Data
SMARTY_AUTH_ID=your_smarty_auth_id
SMARTY_AUTH_TOKEN=your_smarty_auth_token

# Storage
STORAGE_BUCKET=disaster-direct-storage

# Xactimate
XACTIMATE_API_URL=https://api.xactimate.com
XACTIMATE_API_KEY=your_xactimate_api_key

# AI Services
OPENAI_API_KEY=sk-your_openai_api_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
XAI_API_KEY=your_xai_api_key
