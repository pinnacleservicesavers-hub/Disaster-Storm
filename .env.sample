# ==============================================
# DISASTER DIRECT - Environment Configuration
# ==============================================
# Copy this file to `.env` and fill in your values
#
# QUICK START:
# 1. Copy: cp .env.sample .env
# 2. Fill in required secrets (marked with *** REQUIRED ***)
# 3. Run: npm install
# 4. Run: npm run db:push --force
# 5. Run: npm run dev
# ==============================================

# ------------------------------------------
# Database (*** REQUIRED ***)
# ------------------------------------------
# PostgreSQL connection string from Neon/Supabase/local
DATABASE_URL=postgresql://user:password@localhost:5432/disaster_direct

# ------------------------------------------
# Weather Data Services
# ------------------------------------------
# Ambee Environmental Intelligence
GETAMBEE_API_KEY=your_ambee_api_key_here

# Xweather Storm Intelligence
XWEATHER_CLIENT_ID=your_xweather_client_id
XWEATHER_CLIENT_SECRET=your_xweather_client_secret

# Tomorrow.io Weather
TOMORROW_API_KEY=your_tomorrow_api_key

# Google Maps (for geocoding and map tiles)
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key

# NASA FIRMS Wildfire Detection (optional)
NASA_FIRMS_API_KEY=your_nasa_firms_api_key

# ------------------------------------------
# AI & ML Services (*** REQUIRED ***)
# ------------------------------------------
# xAI Grok (primary AI intelligence engine)
XAI_API_KEY=your_xai_grok_api_key

# OpenAI (GPT models for AI assistant)
OPENAI_API_KEY=your_openai_api_key

# Anthropic Claude (damage detection, image analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key

# ------------------------------------------
# Communication Services
# ------------------------------------------
# Twilio SMS/Voice (*** REQUIRED for contractor alerts ***)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid Email (optional, for email alerts)
SENDGRID_API_KEY=your_sendgrid_api_key
CLAIMS_FROM_EMAIL=alerts@yourdomain.com
CLAIMS_FROM_NAME=Disaster Direct Alerts

# Slack Integration (optional)
SLACK_BOT_TOKEN=your_slack_bot_token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# ------------------------------------------
# Voice AI Services
# ------------------------------------------
# ElevenLabs Text-to-Speech (for voice assistant)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ------------------------------------------
# Payment & Legal Services
# ------------------------------------------
# Stripe Payment Processing (for subscriptions)
STRIPE_SECRET_KEY=your_stripe_secret_key
VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key
TESTING_STRIPE_SECRET_KEY=your_test_stripe_secret_key
TESTING_VITE_STRIPE_PUBLIC_KEY=your_test_stripe_public_key

# Dropbox Sign (for electronic signatures)
DROPBOX_SIGN_API_KEY=your_dropbox_sign_api_key

# ------------------------------------------
# Property Data Services
# ------------------------------------------
# Smarty Address Validation
SMARTY_AUTH_ID=your_smarty_auth_id
SMARTY_AUTH_TOKEN=your_smarty_auth_token

# ATTOM Property Data
ATTOM_API_KEY=your_attom_api_key

# Melissa Address Verification
MELISSA_API_KEY=your_melissa_api_key

# EagleView Aerial Imagery
EAGLEVIEW_API_KEY=your_eagleview_api_key

# ------------------------------------------
# Object Storage (for media uploads)
# ------------------------------------------
# Replit Object Storage (automatically configured in Replit)
# Or use Supabase/AWS S3
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------------------------------
# Application Settings
# ------------------------------------------
# Environment (development, staging, production)
NODE_ENV=development

# Base URL for the application
PUBLIC_BASE_URL=http://localhost:5000

# Session Secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your_session_secret_here

# ------------------------------------------
# SMTP Configuration (optional email)
# ------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@disasterdirect.com

# ------------------------------------------
# Feature Flags
# ------------------------------------------
# Enable/disable specific features
ENABLE_MRMS_PROCESSING=true
ENABLE_CONTRACTOR_ALERTS=true
ENABLE_AI_DAMAGE_DETECTION=true

# ------------------------------------------
# MRMS Processing Configuration
# ------------------------------------------
# How often to process MRMS data (in minutes)
MRMS_PROCESSING_INTERVAL=15

# Service areas for MRMS geofencing (comma-separated)
MRMS_SERVICE_AREAS=miami-dade,broward,palm-beach,houston

# ------------------------------------------
# Contractor Alert Configuration
# ------------------------------------------
# How often to send contractor alerts (in minutes)
CONTRACTOR_ALERT_INTERVAL=15

# Minimum hazard severity to trigger alerts (Minor, Moderate, Severe, Extreme)
CONTRACTOR_ALERT_MIN_SEVERITY=Severe

# ------------------------------------------
# Developer Settings
# ------------------------------------------
# Enable debug logging
DEBUG=false

# Enable SQL query logging
LOG_SQL_QUERIES=false

# Mock external API calls in development
MOCK_EXTERNAL_APIS=true
