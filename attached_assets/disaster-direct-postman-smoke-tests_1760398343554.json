        {
          "name": "Impact GeoJSON",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}",
                "type": "text"
              },
              {
                "key": "x-api-key",
                "value": "{{xApiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/impact/geojson?lat={{lat}}&lng={{lng}}&pollen=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "impact",
                "geojson"
              ],
              "query": [
                {
                  "key": "lat",
                  "value": "{{lat}}"
                },
                {
                  "key": "lng",
                  "value": "{{lng}}"
                },
                {
                  "key": "pollen",
                  "value": "1"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Content is GeoJSON FeatureCollection\", function () {",
                  "  var j = pm.response.json();",
                  "  pm.expect(j).to.have.property(\"type\", \"FeatureCollection\");",
                  "  pm.expect(j.features).to.be.an(\"array\");",
                  "  if (j.features.length) {",
                  "    pm.expect(j.features[0]).to.have.property(\"type\", \"Feature\");",
                  "    pm.expect(j.features[0]).to.have.property(\"properties\");",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
