{
  "info": {
    "name": "Disaster Direct \u2013 Smoke Tests",
    "_postman_id": "6c7c347e-4711-4abd-804b-1db1247b7f49",
    "description": "One-click smoke tests for Disaster Direct proxy. Set environment variables: baseUrl, bearerToken/xApiKey if needed, lat, lng, maxLatencyMs (default 2000).",
