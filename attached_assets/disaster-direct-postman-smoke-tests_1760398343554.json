  "item": [
    {
      "name": "01 Health & Docs",
      "item": [
        {
          "name": "Healthz",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/healthz",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "healthz"
              ],
              "query": []
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const maxMs = parseInt(pm.environment.get(\"maxLatencyMs\") || pm.collectionVariables.get(\"maxLatencyMs\") || \"2000\", 10);",
                  "pm.test(\"Latency under \"+maxMs+\" ms\", function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(maxMs);",
                  "});",
                  "",
                  "pm.test(\"JSON has ok\", function () {",
                  "  pm.response.to.be.withBody;",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.have.property(\"ok\");",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
